{
  "name": "an5-adapters",
  "version": "0.1.0",
  "description": "Standalone language adapters for AN5 ORM - TypeScript, Python, .NET query execution.",
  "license": "MIT",
  "main": "typescript/index.js",
  "types": "typescript/index.d.ts",
  "exports": {
    ".": "./typescript/index.js",
    "./typescript": "./typescript/index.js",
    "./typescript/*": "./typescript/*",
    "./python": "./python/an5_adapter.py",
    "./dotnet": "./dotnet/An5Adapter.cs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/an5ORM/an5Adapters.git"
  },
  "keywords": ["an5", "orm", "adapter", "typescript", "python", "dotnet"],
  "files": [
    "typescript/**/*.{ts,js,d.ts}",
    "python/**/*",
    "dotnet/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "test": "node -e \"const fs = require('fs'); const files = ['typescript/an5Adapter.ts', 'typescript/index.ts']; files.forEach(f => { if (!fs.existsSync(f)) { console.error('Missing: ' + f); process.exit(1); } }); console.log('All adapter files exist');\" 2>&1",
    "test:python": "python -m compileall python 2>&1"
  },
  "dependencies": {
    "mssql": "^12.5.5"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.8",
    "@types/node": "^20.11.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
